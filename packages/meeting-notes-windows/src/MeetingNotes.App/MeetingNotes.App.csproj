<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Windows desktop UI (WPF). Windows-only - builds on the windows-latest CI
    runner, not on the macOS dev machine. WPF (not WinUI 3) so it compiles with a
    plain `dotnet build` and ships as a self-contained .exe, no MSIX identity.
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\MeetingNotes.Core\MeetingNotes.Core.csproj" />
    <ProjectReference Include="..\MeetingNotes.Audio\MeetingNotes.Audio.csproj" />
  </ItemGroup>

  <!--
    Bundle a self-contained whisper-cli.exe (and any VAD/model files) dropped into
    vendor/ by scripts/setup-whisper.ps1, so the app finds it next to its exe via
    ModelDownloader.ResolveWhisperCli() with no PATH setup. Optional - when absent
    the user just points the whisper-cli.exe path at their own copy in Settings.
  -->
  <ItemGroup>
    <Content Include="vendor\**" CopyToOutputDirectory="PreserveNewest" Condition="Exists('vendor')" />
  </ItemGroup>

</Project>
<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Portable logic - transcription orchestration, summarization (Ollama/Claude),
    note storage, settings. Pure .NET, no Windows dependency, so it builds and
    unit-tests on any OS (incl. the macOS dev machine).
  -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

</Project>
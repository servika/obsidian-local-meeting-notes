<Project Sdk="Microsoft.NET.Sdk">

  <!--
    WASAPI capture (system loopback + mic) via NAudio. Windows-only - this builds
    on the windows-latest CI runner, NOT on the macOS dev machine.
  -->
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MeetingNotes.Core\MeetingNotes.Core.csproj" />
  </ItemGroup>

</Project>